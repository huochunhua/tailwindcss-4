{
  "name": "Tailwind v4",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "browser-sync start --no-scroll --port 3000 --server --startPath '/src/' & npx @tailwindcss/cli -i ./src/input.css -o ./src/output.css --watch",
    "serves": "browser-sync start --port 3000 --server --no-scroll --startPath '/src/' --no-ghost-mode",
    "serves-files": "browser-sync start --port 3000 --server --directory --files --no-scroll --startPath '/src/index.html' --no-ghost-mode",
    "watch": "npx @tailwindcss/cli -i ./src/input.css -o ./src/output.css --watch",
    "build:css": "npx @tailwindcss/cli -i ./src/input.css -o ./src/output.css"
  },
  "dependencies": {
    "@tailwindcss/cli": "^4.3.1",
    "tailwindcss": "^4.3.1"
  }
}
